# Copy to .env and fill in your key (or just export ANTHROPIC_API_KEY in your shell).
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides.
# Classification is a simple task — set this to claude-haiku-4-5 for a faster,
# cheaper, snappier CLI. Defaults to claude-opus-4-8.
# VIBE_CLASSIFIER_MODEL=claude-haiku-4-5

# Model used for Mode 2 prose generation. Defaults to claude-opus-4-8.
# VIBE_WRITER_MODEL=claude-opus-4-8
